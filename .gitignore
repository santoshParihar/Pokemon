# This .gitignore file is configured for standard Unity projects.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory dumps
# Memory dumps can be created when Unity editor or player crashes.
# These files can be huge and should not be tracked by Git.
sysinfo.txt
*.stackdump

# Crashlytics generated file
crashlytics-build.properties

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File System Templates
/Assets/Templates/

# Windows image detail cache
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# macOS files
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might be created on Free Desktop systems
.directory

# Microsoft Visual Studio files
.vs/
*.userprefs
*.sln.docstates

# Rider IDE files
.idea/
*.sln.iml

# Visual Studio Code files
.vscode/

# Local history (VS Code / Rider / etc.)
.history/

.kilo/

.utmp/
*.txt

 